<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>里程報銷計算器 v3</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang TC", "Microsoft JhengHei", sans-serif; }
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .arrow { transform: rotate(90deg); }
  .arrow { transition: transform 0.2s; display: inline-block; }
</style>
</head>
<body class="bg-gray-50 min-h-screen">
<div class="max-w-2xl mx-auto p-4 md:p-8">

  <header class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">🚗 里程報銷計算器</h1>
  </header>

  <!-- API Key Setup -->
  <section id="apiKeySection" class="bg-orange-50 border border-orange-300 rounded-xl shadow-sm p-4 md:p-5 mb-4">
    <details id="apiKeyDetails">
      <summary class="cursor-pointer font-medium text-orange-900 select-none flex items-center justify-between">
        <span><span class="arrow">▶</span> 🔑 Google API Key 設定</span>
        <span id="apiKeyStatus" class="text-xs font-normal text-orange-700"></span>
      </summary>
      <div class="mt-3">
        <input id="apiKey" type="password" placeholder="貼上你的 API Key（AIzaSy... 開頭）" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-orange-500 text-sm font-mono">
        <p class="text-xs text-gray-600 mt-2">第一次使用要設定一次，會記在這台瀏覽器（localStorage）。<br>申請步驟請看 <code class="bg-orange-100 px-1 rounded">setup_guide.md</code></p>
        <div class="mt-2 flex gap-2 flex-wrap">
          <button id="saveKeyBtn" class="bg-orange-600 hover:bg-orange-700 text-white text-sm px-4 py-2 rounded-lg">儲存</button>
          <button id="clearKeyBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm px-4 py-2 rounded-lg">清除</button>
          <span id="keySavedMsg" class="hidden self-center text-green-700 text-sm font-medium">✅ 已儲存</span>
        </div>
      </div>
    </details>
  </section>

  <!-- Main form -->
  <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 md:p-6 mb-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">業務員姓名</label>
        <input id="staffName" type="text" placeholder="例：王小明" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">日期</label>
        <input id="tripDate" type="date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
      </div>
    </div>
    <div class="mb-3">
      <label class="block text-sm font-medium text-gray-700 mb-1">起點地址 <span class="text-red-500">*</span></label>
      <input id="origin" type="text" placeholder="例：台北市信義區市府路1號" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-1">終點地址 <span class="text-red-500">*</span></label>
      <input id="destination" type="text" placeholder="例：新北市板橋區中山路一段161號" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">每公里費率（NT$）</label>
        <input id="rate" type="number" value="7" min="0" step="0.5" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-sm">
      </div>
      <div class="flex items-end">
        <label class="inline-flex items-center text-sm text-gray-700 cursor-pointer pb-2">
          <input id="roundTrip" type="checkbox" class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
          <span class="ml-2">來回（往返同一路線）</span>
        </label>
      </div>
    </div>

    <button id="calculateBtn" class="w-full bg-blue-600 hover:bg-blue-700 active:bg-blue-800 text-white font-medium px-4 py-3 rounded-lg transition text-sm disabled:opacity-50 disabled:cursor-not-allowed">
      🚀 自動計算公里數與金額
    </button>
  </section>

  <div id="loading" class="hidden bg-blue-50 border border-blue-200 rounded-lg p-3 mb-4 text-blue-800 text-sm">
    ⏳ 計算中，請稍候...
  </div>

  <div id="error" class="hidden bg-red-50 border border-red-200 rounded-lg p-3 mb-4 text-red-800 text-sm"></div>

  <section id="result" class="hidden bg-white rounded-xl shadow-sm border border-gray-200 p-5 md:p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">📊 計算結果</h2>

    <div id="durationInfo" class="hidden bg-blue-50 border border-blue-200 rounded-lg p-3 mb-3 text-xs text-blue-900"></div>
    
    <div class="mb-3">
      <label class="block text-sm font-medium text-gray-700 mb-1">
        單程公里數 <span class="text-xs text-gray-500 font-normal">（自動帶入，可手動修正）</span>
      </label>
      <input id="distanceKm" type="number" step="0.1" min="0" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 text-base font-semibold">
    </div>
    
    <div class="bg-gray-50 rounded-lg p-4 space-y-2 mb-4">
      <div class="flex justify-between text-sm">
        <span class="text-gray-600">總公里數</span>
        <span id="totalKm" class="font-medium text-gray-900">-</span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-gray-600">每公里費率</span>
        <span id="rateDisplay" class="font-medium text-gray-900">-</span>
      </div>
      <div class="flex justify-between pt-2 border-t border-gray-200">
        <span class="font-medium text-gray-900">報銷金額</span>
        <span id="totalAmount" class="text-2xl font-bold text-blue-600">-</span>
      </div>
    </div>

    <button id="copyBtn" class="w-full bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-medium px-4 py-2.5 rounded-lg transition text-sm">
      📋 複製報帳記錄
    </button>
    
    <p id="copySuccess" class="hidden text-green-600 text-sm mt-2 text-center font-medium">✅ 已複製，可貼到 Excel 或表單</p>
  </section>

  <section class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-900">
    <p class="font-medium mb-2">💡 使用說明</p>
    <ul class="list-disc list-inside space-y-1 text-xs">
      <li>第一次使用：先點「🔑 API Key 設定」貼上 key（一次設定即可）</li>
      <li>填好業務員、日期、起終點地址 → 點「🚀 自動計算」</li>
      <li>系統會自動帶出公里數，可手動修正；改費率/勾來回，金額會即時重算</li>
      <li>「📋 複製報帳記錄」會把整筆資料格式化複製到剪貼簿</li>
    </ul>
  </section>

</div>

<script>
  // ╔═══════════════════════════════════════════════════════════╗
  // ║  ⚙️  設定區：把你的 Google API Key 埋在這裡                  ║
  // ║                                                            ║
  // ║  ▸ 把下面引號裡的內容換成你的 key                          ║
  // ║    例：const HARDCODED_API_KEY = 'AIzaSyABCD1234...';       ║
  // ║                                                            ║
  // ║  ▸ 留空（''）的話，會顯示輸入框讓使用者自己貼              ║
  // ║                                                            ║
  // ║  ⚠️  Key 一定要在 Google Cloud Console 設好 Referrer 限制   ║
  // ║      （setup_guide.md Step 6），否則被偷會被燒帳單         ║
  // ╚═══════════════════════════════════════════════════════════╝
  const HARDCODED_API_KEY = '';
  // ═══════════════════════════════════════════════════════════════

  const STORAGE_KEY = 'mileage_calc_api_key';
  let apiKey = '';
  
  const els = {
    apiKey: document.getElementById('apiKey'),
    apiKeyStatus: document.getElementById('apiKeyStatus'),
    apiKeyDetails: document.getElementById('apiKeyDetails'),
    saveKeyBtn: document.getElementById('saveKeyBtn'),
    clearKeyBtn: document.getElementById('clearKeyBtn'),
    keySavedMsg: document.getElementById('keySavedMsg'),
    staffName: document.getElementById('staffName'),
    tripDate: document.getElementById('tripDate'),
    origin: document.getElementById('origin'),
    destination: document.getElementById('destination'),
    distanceKm: document.getElementById('distanceKm'),
    roundTrip: document.getElementById('roundTrip'),
    rate: document.getElementById('rate'),
    calculateBtn: document.getElementById('calculateBtn'),
    copyBtn: document.getElementById('copyBtn'),
    loading: document.getElementById('loading'),
    error: document.getElementById('error'),
    result: document.getElementById('result'),
    durationInfo: document.getElementById('durationInfo'),
    totalKm: document.getElementById('totalKm'),
    rateDisplay: document.getElementById('rateDisplay'),
    totalAmount: document.getElementById('totalAmount'),
    copySuccess: document.getElementById('copySuccess'),
  };

  function showError(msg) {
    els.error.textContent = '❌ ' + msg;
    els.error.classList.remove('hidden');
    els.loading.classList.add('hidden');
  }

  function hideError() {
    els.error.classList.add('hidden');
  }

  function safeStorageGet(key) {
    try { return localStorage.getItem(key); } catch (e) { return null; }
  }
  function safeStorageSet(key, val) {
    try { localStorage.setItem(key, val); return true; } catch (e) { return false; }
  }
  function safeStorageRemove(key) {
    try { localStorage.removeItem(key); } catch (e) {}
  }

  function updateApiKeyStatus() {
    if (apiKey) {
      els.apiKeyStatus.textContent = `✅ 已設定（${apiKey.slice(0, 8)}...）`;
    } else {
      els.apiKeyStatus.textContent = '⚠️ 尚未設定';
    }
  }

  // ===== Key 管理 =====
  if (HARDCODED_API_KEY) {
    apiKey = HARDCODED_API_KEY;
    const apiKeySection = document.getElementById('apiKeySection');
    if (apiKeySection) apiKeySection.style.display = 'none';
  } else {
    apiKey = safeStorageGet(STORAGE_KEY) || '';
    if (apiKey) {
      els.apiKey.value = apiKey;
      els.apiKeyDetails.open = false;
    } else {
      els.apiKeyDetails.open = true;
    }
    updateApiKeyStatus();
  }

  els.saveKeyBtn?.addEventListener('click', () => {
    const v = els.apiKey.value.trim();
    if (!v) { showError('請貼上 API Key'); return; }
    apiKey = v;
    const saved = safeStorageSet(STORAGE_KEY, v);
    updateApiKeyStatus();
    els.keySavedMsg.textContent = saved ? '✅ 已儲存' : '✅ 已設定（本次有效，瀏覽器不支援儲存）';
    els.keySavedMsg.classList.remove('hidden');
    setTimeout(() => els.keySavedMsg.classList.add('hidden'), 2500);
    hideError();
  });

  els.clearKeyBtn?.addEventListener('click', () => {
    apiKey = '';
    els.apiKey.value = '';
    safeStorageRemove(STORAGE_KEY);
    updateApiKeyStatus();
    els.apiKeyDetails.open = true;
  });

  // ===== Routes API 呼叫 =====
  function formatDuration(d) {
    if (!d) return '-';
    const seconds = parseInt(String(d).replace('s', ''), 10);
    if (isNaN(seconds)) return '-';
    const minutes = Math.round(seconds / 60);
    if (minutes < 60) return `${minutes} 分鐘`;
    const hours = Math.floor(minutes / 60);
    const mins = minutes % 60;
    return mins > 0 ? `${hours} 小時 ${mins} 分鐘` : `${hours} 小時`;
  }

  async function calculateDistance(origin, destination) {
    let response;
    try {
      response = await fetch('https://routes.googleapis.com/directions/v2:computeRoutes', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Goog-Api-Key': apiKey,
          'X-Goog-FieldMask': 'routes.distanceMeters,routes.duration'
        },
        body: JSON.stringify({
          origin: { address: origin },
          destination: { address: destination },
          travelMode: 'DRIVE',
          routingPreference: 'TRAFFIC_UNAWARE',
          languageCode: 'zh-TW',
          regionCode: 'TW',
          units: 'METRIC'
        })
      });
    } catch (e) {
      throw new Error('網路錯誤：無法連線到 Google Routes API（' + e.message + '）');
    }

    if (!response.ok) {
      let detail = '';
      try {
        const errData = await response.json();
        detail = errData?.error?.message || errData?.error?.status || '';
      } catch (e) {}
      
      if (response.status === 403) {
        throw new Error('API 拒絕（403）：請確認 (1) Routes API 已啟用 (2) Referrer 限制符合此網域 (3) 結帳帳戶已啟用。詳細：' + detail);
      } else if (response.status === 400) {
        throw new Error('請求格式錯誤（400）：可能是地址不完整或語法錯誤。詳細：' + detail);
      } else if (response.status === 429) {
        throw new Error('超過配額（429）：請檢查 Cloud Console 的配額設定。詳細：' + detail);
      } else {
        throw new Error(`Routes API 錯誤（${response.status}）：${detail}`);
      }
    }

    const data = await response.json();
    if (!data.routes || data.routes.length === 0) {
      throw new Error('找不到行駛路線——請確認地址完整（含縣市、路名、門牌號）且兩地之間可駕駛抵達');
    }

    const route = data.routes[0];
    return {
      km: route.distanceMeters / 1000,
      duration: formatDuration(route.duration),
    };
  }

  // ===== 計算流程 =====
  els.calculateBtn.addEventListener('click', async () => {
    if (!apiKey) {
      showError('請先設定 API Key（點上方「🔑 Google API Key 設定」）');
      els.apiKeyDetails.open = true;
      return;
    }
    
    const origin = els.origin.value.trim();
    const destination = els.destination.value.trim();
    if (!origin || !destination) {
      showError('請輸入起點與終點地址');
      return;
    }

    hideError();
    els.loading.classList.remove('hidden');
    els.result.classList.add('hidden');
    els.calculateBtn.disabled = true;

    try {
      const r = await calculateDistance(origin, destination);
      
      els.distanceKm.value = r.km.toFixed(1);
      els.durationInfo.textContent = `🕐 預估行車時間：${r.duration}`;
      els.durationInfo.classList.remove('hidden');
      updateResult();
      
      els.loading.classList.add('hidden');
      els.result.classList.remove('hidden');
    } catch (err) {
      showError(err.message);
    } finally {
      els.calculateBtn.disabled = false;
    }
  });

  function updateResult() {
    const km = parseFloat(els.distanceKm.value) || 0;
    const isRoundTrip = els.roundTrip.checked;
    const rate = parseFloat(els.rate.value) || 0;
    const totalKm = isRoundTrip ? km * 2 : km;
    const amount = totalKm * rate;
    
    els.totalKm.textContent = km > 0 ? `${totalKm.toFixed(1)} 公里 ${isRoundTrip ? '（來回）' : '（單程）'}` : '-';
    els.rateDisplay.textContent = `NT$ ${rate} / 公里`;
    els.totalAmount.textContent = `NT$ ${Math.round(amount).toLocaleString()}`;
  }

  [els.distanceKm, els.roundTrip, els.rate].forEach(el => {
    el.addEventListener('input', updateResult);
    el.addEventListener('change', updateResult);
  });

  els.copyBtn.addEventListener('click', async () => {
    const km = parseFloat(els.distanceKm.value) || 0;
    if (km <= 0) { showError('沒有公里數可複製'); return; }
    
    const staff = els.staffName.value.trim() || '(未填)';
    const date = els.tripDate.value || '(未填)';
    const origin = els.origin.value.trim();
    const destination = els.destination.value.trim();
    const isRoundTrip = els.roundTrip.checked;
    const rate = parseFloat(els.rate.value) || 0;
    const totalKm = isRoundTrip ? km * 2 : km;
    const amount = Math.round(totalKm * rate);

    const record = `日期：${date}
業務員：${staff}
起點：${origin}
終點：${destination}
單程：${km.toFixed(1)} 公里
總公里數：${totalKm.toFixed(1)} 公里${isRoundTrip ? '（來回）' : '（單程）'}
費率：NT$ ${rate} / 公里
報銷金額：NT$ ${amount.toLocaleString()}`;

    let copied = false;
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(record);
        copied = true;
      }
    } catch (e) {}
    
    if (!copied) {
      const ta = document.createElement('textarea');
      ta.value = record;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); copied = true; } catch (e) {}
      document.body.removeChild(ta);
    }

    if (copied) {
      els.copySuccess.classList.remove('hidden');
      setTimeout(() => els.copySuccess.classList.add('hidden'), 2500);
    } else {
      showError('複製失敗，請手動選取結果文字');
    }
  });

  els.tripDate.valueAsDate = new Date();
  updateResult();
</script>
</body>
</html>
